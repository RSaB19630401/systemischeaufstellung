{
  "name": "systemische-aufstellung",
  "version": "1.0.0",
  "description": "KI-gestützte systemische Aufstellung – geführt durch einen Coach-Dialog mit interaktivem Whiteboard",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "worker:dev": "cd worker && wrangler dev",
    "worker:deploy": "cd worker && wrangler deploy",
    "worker:secret": "cd worker && wrangler secret put ANTHROPIC_API_KEY"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "wrangler": "^3.99.0"
  },
  "license": "MIT"
}
